<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }}{% else %}Magalie Chetrit — Web Developer{% endif %}</title>
    <meta name="description" content="{% if description %}{{ description }}{% else %}Magalie Chetrit is a web developer based in New Jersey with 20+ years of experience in WordPress, WooCommerce, React, and modern front-end tools.{% endif %}">
    <meta name="robots" content="index, follow">

    <!-- Open Graph -->
    <meta property="og:title" content="{% if title %}{{ title }}{% else %}Magalie Chetrit — Web Developer{% endif %}">
    <meta property="og:description" content="{% if description %}{{ description }}{% else %}Magalie Chetrit is a web developer based in New Jersey with 20+ years of experience in WordPress, WooCommerce, React, and modern front-end tools.{% endif %}">
    <meta property="og:type" content="{% if ogType %}{{ ogType }}{% else %}website{% endif %}">
    <meta property="og:url" content="https://magaliechetrit.com{{ page.url }}">
    <meta property="og:site_name" content="Magalie Chetrit">

    <!-- Canonical -->
    <link rel="canonical" href="https://magaliechetrit.com{{ page.url }}">

    <link rel="stylesheet" href="/assets/css/lite.css">
</head>
<body>
    <div class="lite-wrap">

        <a href="#main-content" class="lite-skip">Skip to main content</a>

        <header class="lite-header">
            <a href="/" class="site-title">Magalie Chetrit</a>
            <nav class="lite-nav" aria-label="Site navigation">
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/blog/">Blog</a></li>
                    <li><a href="/now/">Now</a></li>
                    <li><a href="/about/">About</a></li>
                </ul>
            </nav>
        </header>

        <main id="main-content">
            {{ content | safe }}
        </main>

        <footer class="lite-footer">
            <p>© Magalie Chetrit {% year %}. &nbsp;·&nbsp;
               <a href="mailto:magaliechetrit+website@gmail.com">Email</a> &nbsp;·&nbsp;
               <a href="https://www.linkedin.com/in/magaliechetrit/">LinkedIn</a> &nbsp;·&nbsp;
               <a href="https://github.com/bluepraise">GitHub</a>
            </p>
            <p class="muted">Last updated: {% lastCommitDate %} (commit: {% lastCommitHash %})</p>
        </footer>

    </div>
</body>
</html>
