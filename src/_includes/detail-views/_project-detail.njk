---
layout: 'base-lite.njk'
---
{% set technologies = technologies | default([]) %}
<article class="project-detail">
    <p><a href="/portfolio/" class="back-link">← Back to portfolio</a></p>

    <h1>{{ title }}</h1>
    {% if subtitle %}
        <p class="subtitle">{{ subtitle }}</p>
    {% endif %}

    <div class="article-meta">
        {% if dateCreated %}
            <time datetime="{{ dateCreated }}">{{ dateCreated | makeDateReadable }}</time>
        {% endif %}
        {% if dateModified %}
            · Updated: <time datetime="{{ dateModified }}">{{ dateModified | makeDateReadable }}</time>
        {% endif %}
        {% if technologies %}
            · {{ technologies | join(', ') }}
        {% endif %}
    </div>

    {% if technologies %}
    <div class="tech-stack-list">
        <strong>Tech:</strong> {{ technologies | join(', ') }}
    </div>
    {% endif %}

    <section class="article-content">
        {{ content | safe }}
    </section>
</article>
