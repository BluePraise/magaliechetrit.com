---
layout: 'base-lite.njk'
---
<article class="article-detail">
    <p><a href="/blog/" class="back-link">← Back to blog</a></p>

    <header class="article-header">
        {% if series %}
            <p class="muted">Part {{ seriesNumber }} of the "{{ series }}" series</p>
        {% endif %}
        <h1>{{ title }}</h1>
        <div class="article-meta">
            <time datetime="{{ dateCreated }}">{{ dateCreated | makeDateReadable }}</time>
            {% if dateModified %}
                · <span>Updated: <time datetime="{{ dateModified }}">{{ dateModified | makeDateReadable }}</time></span>
            {% endif %}
        </div>
    </header>

    <section class="article-content">
        {{ content | safe }}
    </section>

    {% if series %}
    <div class="series-navigation lite-section">
        <h2>More in the "{{ series }}" series</h2>

        {% set previousPost = collections.post | getPreviousInSeries(page) %}
        {% set nextPost = collections.post | getNextInSeries(page) %}

        <div class="series-links">
            {% if previousPost %}
                <a href="{{ previousPost.url }}" class="series-prev">← {{ previousPost.data.title }}</a>
            {% endif %}
            {% if nextPost %}
                <a href="{{ nextPost.url }}" class="series-next">{{ nextPost.data.title }} →</a>
            {% endif %}
        </div>

        <ol class="series-list">
            {% for post in collections.post | getSeriesPosts(series) %}
            <li{% if post.url == page.url %} class="current"{% endif %}>
                <a href="{{ post.url }}">{{ post.data.title }}</a>
            </li>
            {% endfor %}
        </ol>
    </div>
    {% endif %}
</article>
