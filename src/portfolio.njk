<h1>Portfolio</h1>
<p>A selection of my work across web development and design.</p>

<section class="lite-section" aria-labelledby="work-title">
    <h2 id="work-title">Selected Projects</h2>
    <ul class="lite-post-list">
        {%- for project in collections.project | sortByDateCreated -%}
        <li>
            <a href="{{ project.url }}">{{ project.data.title }}</a>
            {% if project.data.technologies %}
                <p class="excerpt">{{ project.data.technologies | join(', ') }}</p>
            {% endif %}
            {% if project.data.dateCreated %}
                <time datetime="{{ project.data.dateCreated }}">{{ project.data.dateCreated | makeDateReadable }}</time>
            {% endif %}
        </li>
        {%- endfor -%}
    </ul>
</section>

<section class="lite-section" aria-labelledby="rates-title">
    <h2 id="rates-title">Rates</h2>
    <ul>
        <li><strong>Hourly:</strong> $65/hour</li>
        <li><strong>Project:</strong> Starting at $2,500/project</li>
        <li><strong>Retainer:</strong> $200/month for ongoing support and maintenance</li>
    </ul>
    <p>Interested in working together? <a href="mailto:magaliechetrit+website@gmail.com">Email me</a> to discuss your project.</p>
</section>
